+package com.example.aidm // Or your data package
+
+import kotlinx.coroutines.delay
+import kotlinx.coroutines.flow.MutableStateFlow
+import kotlinx.coroutines.flow.StateFlow
+import kotlinx.coroutines.flow.asStateFlow
+import kotlinx.coroutines.sync.Mutex
+import kotlinx.coroutines.sync.withLock
+
+// Assuming IncidentData is still used by other parts of your app using FakeRepo
+data class IncidentData(
+    val type: String,
+    val description: String,
+    val latitude: Double,
+    val longitude: Double,
+    val timestamp: Long = System.currentTimeMillis()
+)
+
+class FakeRepo {
+    private val mutex = Mutex()
+    private val _incidents = MutableStateFlow<List<IncidentData>>(emptyList())
+    val incidents: StateFlow<List<IncidentData>> = _incidents.asStateFlow()
+
+    suspend fun submitIncident(type: String, description: String, lat: Double, lng: Double): Boolean {
+        delay(500)
+        val newIncident = IncidentData(type, description, lat, lng)
+        mutex.withLock {
+            _incidents.value = _incidents.value + newIncident
+        }
+        return true
+    }
+
+    fun getIncidentsFlow(): StateFlow<List<IncidentData>> {
+        return incidents
+    }
+
+    suspend fun getAnnouncements(): List<String> {
+        delay(200)
+        return _incidents.value.map {
+            "New Incident Reported: ${it.type} - ${it.description.take(50)}${if (it.description.length > 50) "..." else ""}"
+        }.reversed()
+    }
+
+    // --- ADD THIS METHOD ---
+    suspend fun getFirstAidTopics(): Map<String, List<String>> {
+        delay(800) // Simulate fetching data
+        return mapOf(
+            "Cuts and Scrapes" to listOf(
+                "Stop the bleeding by applying pressure.",
+                "Clean the wound with water.",
+                "Apply an antibiotic ointment.",
+                "Cover the wound with a bandage."
+            ),
+            "Burns (Minor)" to listOf(
+                "Cool the burn with cool (not ice-cold) running water for 10-15 minutes.",
+                "Cover with a sterile non-adhesive bandage or clean cloth.",
+                "Do not apply ointments or butter."
+            ),
+            "Sprains" to listOf(
+                "Rest the injured limb.",
+                "Ice the area for 20 minutes at a time, several times a day.",
+                "Compress the area with an elastic bandage.",
+                "Elevate the injured limb above your heart."
+            ),
+            "Choking (Adult)" to listOf(
+                "Ask: 'Are you choking?'",
+                "If the person can cough or speak, encourage them to keep coughing.",
+                "If they cannot speak, breathe, or cough, perform the Heimlich maneuver (abdominal thrusts).",
+                "Call for emergency help immediately if the blockage isn't cleared."
+            )
+        )
+    }
+}
